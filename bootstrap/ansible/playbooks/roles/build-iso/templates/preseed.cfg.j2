### GRUB
### =========================

d-i grub-efi-amd64-signed/uefi boolean {{ preseed.grub.uefi | lower }}
d-i grub-installer/force-efi-extra-removable boolean {{ preseed.grub.removable | lower }}

### =========================
### SSH + SUDO
### =========================

d-i preseed/late_command string 
in-target mkdir -p /home/{{ preseed.user.username }}/.ssh; 
echo "{{ preseed.ssh.public_key }}" > /target/home/{{ preseed.user.username }}/.ssh/authorized_keys; 
in-target chown -R {{ preseed.user.username }}:{{ preseed.user.username }} /home/{{ preseed.user.username }}/.ssh; 
in-target chmod 700 /home/{{ preseed.user.username }}/.ssh; 
in-target chmod 600 /target/home/{{ preseed.user.username }}/.ssh/authorized_keys; 
{% if preseed.sudo.nopasswd %}
echo "{{ preseed.user.username }} ALL=(ALL) NOPASSWD:ALL" > /target/etc/sudoers.d/{{ preseed.user.username }}; 
in-target chmod 440 /etc/sudoers.d/{{ preseed.user.username }}
in-target systemctl enable incus;
in-target systemctl start incus;
in-target incus storage create default dir;
in-target incus launch images:fedora/44 vm1 --vm;
{% endif %}



### =========================
### FINALIZAÇÃO
### =========================

d-i finish-install/reboot_in_progress note
