### =========================
### USUÁRIO
### =========================

d-i passwd/root-login boolean {{ preseed.user.root_login | lower }}
d-i passwd/user-fullname string {{ preseed.user.fullname }}
d-i passwd/username string {{ preseed.user.username }}
d-i passwd/user-password password {{ preseed.user.password }}
d-i passwd/user-password-again password {{ preseed.user.password }}
d-i passwd/user-default-groups string {{ preseed.user.default_groups | join(',') }}

### =========================
### UEFI + GPT + BTRFS
### =========================
### Partitioning

# Força modo UEFI (sem compatibilidade BIOS)
d-i partman-efi/non_efi_system boolean {{ preseed.partitioning.uefi | lower }}

# Garante tabela GPT (obrigatório para UEFI)
d-i partman-partitioning/choose_label select {{ preseed.partitioning.label }}
d-i partman-partitioning/default_label string {{ preseed.partitioning.label }}

# Usar Btfs como filesystem padrão
d-i partman/default_filesystem string {{ preseed.partitioning.filesystem }}
d-i partman-basicfilesystems/default_label string {{ preseed.partitioning.label }}

# Seleciona particionamento assistido usando o disco inteiro
d-i partman-auto/init_automatically_partition select largest_free
d-i partman-auto/method string regular
d-i partman-auto/choose_recipe select {{ preseed.partitioning.recipe }}

# Disco a ser particionado (SCI2 (0,0,0) = /dev/sda)
#d-i partman-auto/disk string {{ preseed.partitioning.disk }}

# Confirmações automáticas (sem perguntas)
d-i partman-partitioning/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

### Popularity contest
# Não participar do levantamento de uso de pacotes
popularity-contest popularity-contest/participate boolean false

### =========================
### PACOTES
### =========================

tasksel tasksel/first multiselect {{ preseed.packages.tasks | join(',') }}
d-i pkgsel/include string {{ preseed.packages.include | join(' ') }}
d-i pkgsel/upgrade select {{ preseed.packages.upgrade }}

